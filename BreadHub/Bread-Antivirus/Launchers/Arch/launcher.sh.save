EOF

# Prompt loop
while true; do
    echo
    read -p "Type /start or /quit: " cmd
    case "$cmd" in
        /start)
            python3 /home/bread/Desktop/BreadHub/Bread-Antivirus/BreadAv-v0.9.9.py
            ;;
        /quit)
            echo "Exiting..."
            break
            ;;
        *)
            echo "Unknown command. Use /start or /quit."
            ;;
    esac
done
