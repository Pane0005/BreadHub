#!/bin/bash

# Set custom terminal title
echo -e "\e]0;Bread Defender Launcher\a"

# Optional: show logo on left (ASCII art)
cat << "EOF"
 /$$$$$$$                                      /$$
| $$__  $$                                    | $$
| $$  \ $$  /$$$$$$   /$$$$$$   /$$$$$$   /$$$$$$$
| $$$$$$$  /$$__  $$ /$$__  $$ |____  $$ /$$__  $$
| $$__  $$| $$  \__/| $$$$$$$$  /$$$$$$$| $$  | $$
| $$  \ $$| $$      | $$_____/ /$$__  $$| $$  | $$
| $$$$$$$/| $$      |  $$$$$$$|  $$$$$$$|  $$$$$$$
|_______/ |__/       \_______/ \_______/ \_______/



  /$$$$$$              /$$     /$$            /$$
 /$$__  $$            | $$    |__/           |__/
| $$  \ $$ /$$$$$$$  /$$$$$$   /$$ /$$    /$$ /$$  /$$$$$$  /$$   /$$  /$$$$$$$
| $$$$$$$$| $$__  $$|_  $$_/  | $$|  $$  /$$/| $$ /$$__  $$| $$  | $$ /$$_____/
| $$__  $$| $$  \ $$  | $$    | $$ \  $$/$$/ | $$| $$  \__/| $$  | $$|  $$$$$$
| $$  | $$| $$  | $$  | $$ /$$| $$  \  $$$/  | $$| $$      | $$  | $$ \____  $$
